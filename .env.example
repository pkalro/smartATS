# --- Database (Neon, Supabase, or local Postgres) ---
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# --- NextAuth ---
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-me"
# In dev: http://localhost:3000  | In prod: your deployed URL
AUTH_URL="http://localhost:3000"

# --- Google OAuth ---
# Create at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: {AUTH_URL}/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# --- Anthropic (Claude) ---
# Get at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=""

# --- Usage caps (per user, per calendar month) ---
# These are AI calls. Warning is shown when usage crosses (cap - WARN_BUFFER).
USAGE_CAP_PER_MONTH=100
USAGE_WARN_BUFFER=10
